# --- AWS Bedrock (Claude Sonnet 4.6) ---
# Region con acceso a Claude Sonnet 4.6 habilitado en Bedrock.
AWS_REGION=us-east-1

# Credenciales: usa claves estaticas O un perfil (AWS_PROFILE). El SDK resuelve
# por la cadena estandar de AWS.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=        # si usas credenciales temporales
# AWS_PROFILE=default       # alternativa a las claves estaticas

# ID del modelo en Bedrock. Default: anthropic.claude-sonnet-4-6
# Si tu cuenta exige inference profile regional, usa el prefijo de region, p.ej.:
#   us.anthropic.claude-sonnet-4-6  /  eu.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# --- Base de datos (Postgres via Prisma + Supabase) ---
# En Supabase: boton "Connect" -> pestana "ORM" -> Prisma. Te da las dos cadenas:
#   DATABASE_URL = Transaction pooler (puerto 6543, con ?pgbouncer=true) -> runtime de la app.
#   DIRECT_URL   = Conexion directa (puerto 5432) -> migraciones de Prisma.
DATABASE_URL=
DIRECT_URL=

# --- Clerk (manejo de sesion) ---
# Claves del dashboard de Clerk: https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
