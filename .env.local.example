# --- AWS Bedrock (Claude Sonnet 4.6) ---
# Region con acceso a Claude Sonnet 4.6 habilitado en Bedrock.
AWS_REGION=us-east-1

# Credenciales: usa claves estaticas O un perfil (AWS_PROFILE). El SDK resuelve
# por la cadena estandar de AWS.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=        # si usas credenciales temporales
# AWS_PROFILE=default       # alternativa a las claves estaticas

# ID del modelo en Bedrock. Default: anthropic.claude-sonnet-4-6
# Si tu cuenta exige inference profile regional, usa el prefijo de region, p.ej.:
#   us.anthropic.claude-sonnet-4-6  /  eu.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6
